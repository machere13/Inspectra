<div class="PageProfile PageProfileConfig">
  <%= render 'shared/wrappers/W_PageHeader' %>

  <section class="PageProfileConfig-Layout">
    <header class="PageProfileConfig-Heading">
      <h2 class="PageProfileConfig-Heading-Title text-h3"><%= t('pages.profile_config.heading') %></h2>
      <p class="PageProfileConfig-Heading-Sub text-p-3"><%= t('pages.profile_config.subheading') %></p>
    </header>

    <div class="PageProfileConfig-Bento">

      <%# ===== IDENTITY (span 6) — hero-аватар слева, поля справа ===== %>
      <article class="PageProfileConfig-Block PageProfileConfig-Block--Identity">
        <header class="PageProfileConfig-Block-Header">
          <span class="PageProfileConfig-Block-Label text-p-3"><%= t('pages.profile_config.account.title') %></span>
          <span class="PageProfileConfig-Block-Tag text-p-3">/ 01</span>
        </header>

        <div class="PageProfileConfig-Identity">
          <%# === AVATAR (большой, кликабельный, авто-сабмит) === %>
          <%= form_with url: update_avatar_path, method: :patch, local: true, multipart: true, id: 'config-avatar-form', class: 'PageProfileConfig-Avatar' do |f| %>
            <label for="config-avatar-upload" class="PageProfileConfig-AvatarThumb" title="<%= @user.avatar.attached? ? t('pages.profile.avatar.change') : t('pages.profile.avatar.upload') %>">
              <%= image_tag avatar_url_for(@user), alt: @user.name || @user.email %>
              <span class="PageProfileConfig-AvatarThumb-Overlay text-p-3">
                <%= @user.avatar.attached? ? t('pages.profile.avatar.change', default: 'Сменить') : t('pages.profile.avatar.upload', default: 'Загрузить') %>
              </span>
              <%= f.file_field :avatar,
                               accept: 'image/*',
                               class: 'PageProfileConfig-AvatarInput',
                               id: 'config-avatar-upload',
                               onchange: "document.getElementById('config-avatar-form').requestSubmit();" %>
            </label>
          <% end %>

          <%# === Поля справа === %>
          <div class="PageProfileConfig-Identity-Fields">

            <%# Имя — редактируется === %>
            <div class="PageProfileConfig-Row">
              <span class="PageProfileConfig-Field-Label text-p-3"><%= t('pages.profile_config.account.name') %></span>
              <%= form_with url: update_name_path, method: :patch, local: true, class: 'PageProfileConfig-Row-Edit' do %>
                <%= render 'shared/atoms/A_Input',
                           name: 'name',
                           type: 'text',
                           value: @user.name,
                           placeholder: t('pages.profile.name_placeholder'),
                           autocomplete: 'name',
                           maxlength: 60 %>
                <%= render 'shared/atoms/A_Button', type: 'submit', text: t('pages.profile_config.actions.save') %>
              <% end %>
            </div>

            <div class="PageProfileConfig-Row PageProfileConfig-Row--ReadOnly">
              <span class="PageProfileConfig-Field-Label text-p-3"><%= t('pages.profile_config.account.email') %></span>
              <div class="PageProfileConfig-Row-Value">
                <span class="PageProfileConfig-Static text-p-2"><%= @user.email %></span>
                <span class="PageProfileConfig-Note text-p-3"><%= t('pages.profile_config.account.email_locked') %></span>
              </div>
            </div>

            <div class="PageProfileConfig-Row">
              <span class="PageProfileConfig-Field-Label text-p-3"><%= t('pages.profile_config.account.game_role') %></span>
              <div class="PageProfileConfig-Row-Edit">
                <div class="PageProfileConfig-Row-Value">
                  <% if @user.game_role.present? %>
                    <span class="PageProfileConfig-Pill"><%= @user.game_role_label %></span>
                  <% else %>
                    <span class="PageProfileConfig-Static--Muted text-p-3"><%= t('pages.profile_config.account.game_role_empty') %></span>
                  <% end %>
                </div>
                <%= render 'shared/atoms/A_Button',
                           href: select_game_role_path,
                           text: t(@user.game_role.present? ? 'pages.profile.change_game_role' : 'pages.profile.choose_game_role') %>
              </div>
            </div>

          </div>
        </div>
      </article>

      <article class="PageProfileConfig-Block PageProfileConfig-Block--Theme">
        <header class="PageProfileConfig-Block-Header">
          <span class="PageProfileConfig-Block-Label text-p-3"><%= t('pages.profile_config.preferences.theme') %></span>
          <span class="PageProfileConfig-Block-Tag text-p-3">/ 02</span>
        </header>

        <div class="PageProfileConfig-Block-Body">
          <div class="O_ThemePickerModal-Card-Preview PageProfileConfig-ThemePreview" data-theme="<%= @user.theme || 'dark' %>">
            <span class="O_ThemePickerModal-Card-Bar"></span>
            <span class="O_ThemePickerModal-Card-Surface"></span>
            <span class="O_ThemePickerModal-Card-Line O_ThemePickerModal-Card-Line--1"></span>
            <span class="O_ThemePickerModal-Card-Line O_ThemePickerModal-Card-Line--2"></span>
            <span class="O_ThemePickerModal-Card-Line O_ThemePickerModal-Card-Line--3"></span>
            <span class="O_ThemePickerModal-Card-Accent"></span>
          </div>
          <div class="PageProfileConfig-Block-Headline text-p-2"><%= t("pages.profile_config.preferences.theme_options.#{@user.theme || 'dark'}") %></div>
        </div>

        <div class="PageProfileConfig-Block-Action" data-js-theme-picker-open>
          <%= render 'shared/atoms/A_Button', text: t('pages.profile_config.preferences.theme_modal.open', default: 'Выбрать тему') %>
        </div>
      </article>

      <article class="PageProfileConfig-Block PageProfileConfig-Block--Security">
        <header class="PageProfileConfig-Block-Header">
          <span class="PageProfileConfig-Block-Label text-p-3"><%= t('pages.profile_config.security.title') %></span>
          <span class="PageProfileConfig-Block-Tag text-p-3">/ 03</span>
        </header>

        <div class="PageProfileConfig-Block-Body">
          <div class="PageProfileConfig-Block-Headline text-p-2"><%= t('pages.profile_config.security.password') %></div>
          <p class="PageProfileConfig-Block-Sub text-p-3"><%= t('pages.profile_config.security.password_hint') %></p>
        </div>

        <%= form_with url: request_password_change_path, method: :post, local: true, class: 'PageProfileConfig-Block-Action', data: { turbo_confirm: t('pages.profile_config.security.confirm_password_change') } do %>
          <%= render 'shared/atoms/A_Button', type: 'submit', text: t('pages.profile_config.security.request_password_change') %>
        <% end %>
      </article>

      <article class="PageProfileConfig-Block PageProfileConfig-Block--Session PageProfileConfig-Block--Danger">
        <header class="PageProfileConfig-Block-Header">
          <span class="PageProfileConfig-Block-Label text-p-3"><%= t('pages.profile_config.session.title') %></span>
          <span class="PageProfileConfig-Block-Tag text-p-3">/ 04</span>
        </header>

        <div class="PageProfileConfig-Block-Body">
          <div class="PageProfileConfig-Block-Headline text-p-2"><%= t('pages.profile_config.session.logout') %></div>
          <p class="PageProfileConfig-Block-Sub text-p-3"><%= t('pages.profile_config.session.logout_hint') %></p>
        </div>

        <%= form_with url: logout_path, method: :delete, local: true, class: 'PageProfileConfig-Block-Action', data: { turbo_confirm: t('pages.profile_config.session.logout_confirm') } do %>
          <%= render 'shared/atoms/A_Button', type: 'submit', text: t('pages.profile_config.session.logout_action') %>
        <% end %>
      </article>

      <article class="PageProfileConfig-Block PageProfileConfig-Block--Notifications">
        <header class="PageProfileConfig-Block-Header">
          <span class="PageProfileConfig-Block-Label text-p-3"><%= t('pages.profile_config.preferences.notifications') %></span>
          <span class="PageProfileConfig-Block-Tag text-p-3">/ 05</span>
        </header>

        <div class="PageProfileConfig-Block-Body">
          <p class="PageProfileConfig-Block-Sub text-p-3"><%= t('pages.profile_config.preferences.notifications_desc') %></p>
        </div>

        <div class="PageProfileConfig-Toggle PageProfileConfig-Block-Action">
          <%= button_to update_preferences_path,
                        method: :patch,
                        params: { notifications_email: true },
                        class: ['PageProfileConfig-ToggleBtn', ('PageProfileConfig-ToggleBtn--Active' if @user.notifications_email)].compact.join(' ') do %>
            <span class="text-button"><%= t('pages.profile_config.preferences.notifications_options.on') %></span>
          <% end %>
          <%= button_to update_preferences_path,
                        method: :patch,
                        params: { notifications_email: false },
                        class: ['PageProfileConfig-ToggleBtn', ('PageProfileConfig-ToggleBtn--Active' unless @user.notifications_email)].compact.join(' ') do %>
            <span class="text-button"><%= t('pages.profile_config.preferences.notifications_options.off') %></span>
          <% end %>
        </div>
      </article>

    </div>
  </section>
</div>
