<%
  total_achievements      = Achievement.count
  completed_count         = @completed_achievements.size
  in_progress_count       = @in_progress_achievements.size
  current_xp              = @user.experience_points.to_i
  next_level              = @user.next_level
  next_required           = next_level ? next_level.required_xp : current_xp
%>
<div class="PageProfile">
  <%= render 'shared/wrappers/W_PageHeader' %>

  <section class="PageProfile-Grid">

    <div class="PageProfile-Col PageProfile-Col--Identity">
      <div class="PageProfile-Card PageProfile-Identity">
        <div class="PageProfile-Avatar-Wrapper">
          <% if @user.avatar.attached? %>
            <%= image_tag url_for(@user.avatar), alt: @user.name || @user.email, class: 'PageProfile-Avatar' %>
          <% else %>
            <div class="PageProfile-Avatar PageProfile-Avatar--placeholder"></div>
          <% end %>
          <%= form_with url: update_avatar_path, method: :patch, local: true, multipart: true, class: 'PageProfile-Avatar-Form' do |f| %>
            <%= f.file_field :avatar, accept: 'image/*', class: 'PageProfile-Avatar-Input', id: 'avatar-upload' %>
            <label for="avatar-upload" class="PageProfile-Avatar-Label" title="<%= @user.avatar.attached? ? t('pages.profile.avatar.change') : t('pages.profile.avatar.upload') %>"></label>
          <% end %>
        </div>
        <div class="PageProfile-Identity-Meta">
          <% badges = @user.earned_badges %>
          <div class="PageProfile-Identity-NameRow">
            <span class="PageProfile-Identity-Name text-p-3"><%= @user.name.presence || t('pages.profile.no_name') %></span>
            <% badges.each do |b| %>
              <span class="PageProfile-Identity-Badge text-p-3" title="<%= b[:achievement].name %>"><%= b[:label] %></span>
            <% end %>
          </div>
          <% if @user.game_role.present? %>
            <span class="PageProfile-Identity-Role text-p-3">
              <%= t('pages.profile.game_role') %>: <strong><%= @user.game_role_label %></strong>
            </span>
          <% end %>
          <% if @user.game_role.blank? %>
            <%= link_to t('pages.profile.choose_game_role'), select_game_role_path, class: 'A_TextButton text-p-3' %>
          <% end %>
        </div>
      </div>

      <div class="PageProfile-Card PageProfile-ProgressCard">
        <h3 class="text-p-3 PageProfile-Card-Title"><%= t('pages.profile.progress.title') %></h3>
        <div class="PageProfile-Progress-Body">
          <div class="PageProfile-Progress-Level text-p-2">
            <%= t('pages.profile.level') %> <strong><%= @user.level_number %></strong><% if @user.level %><span class="text-p-3"> · <%= @user.level.name %></span><% end %>
          </div>
          <%
            percent =
              if next_level
                @user.level_progress_percent
              elsif @user.level
                100
              else
                0
              end
          %>
          <div class="PageProfile-LevelProgress-Bar" role="progressbar"
               aria-valuenow="<%= percent %>" aria-valuemin="0" aria-valuemax="100">
            <div class="PageProfile-LevelProgress-Bar-Fill" style="width: <%= percent %>%"></div>
          </div>
          <div class="PageProfile-Progress-XP text-p-3">
            <% if next_level %>
              <%= current_xp %> / <%= next_required %> XP
            <% elsif @user.level %>
              <%= current_xp %> XP · <%= t('pages.profile.progress.max_level') %>
            <% else %>
              <%= current_xp %> XP
            <% end %>
          </div>
        </div>
      </div>

      <%= render 'pages/profile/missions', extra_class: 'PageProfile-Missions--InColumn' %>

    </div>

    <div class="PageProfile-Col PageProfile-Col--Center">
      <div class="PageProfile-Card PageProfile-RadarCard">
        <h3 class="text-p-3 PageProfile-Card-Title"><%= t('pages.profile.skill_chart.title') %></h3>
        <%= render 'pages/profile/M_SkillRadar', rows: @skill_chart %>
      </div>

      <div class="PageProfile-Card PageProfile-Tabs">
        <div class="PageProfile-TabsNav">
          <% %w[achievements titles rewards].each do |tab| %>
            <%= link_to profile_path(tab: tab),
                        class: "PageProfile-TabBtn #{'PageProfile-TabBtn--Active' if @active_tab == tab}" do %>
              <span class="text-p-3"><%= t("pages.profile.tabs.#{tab}") %></span>
            <% end %>
          <% end %>
        </div>

        <div class="PageProfile-TabContent">
          <% case @active_tab
             when 'achievements' %>
            <% if @achievement_groups.any? %>
              <div class="PageProfile-AchievementList">
                <% @achievement_groups.each do |g| %>
                  <div class="PageProfile-AchievementRow <%= 'PageProfile-AchievementRow--Done' if g[:all_completed] %>">
                    <div class="PageProfile-AchievementRow-Body">
                      <div class="PageProfile-AchievementRow-Head">
                        <strong class="text-p-3"><%= g[:tier].name %></strong>
                        <% if g[:all_completed] %><span class="text-p-3">✓</span><% end %>
                        <span class="PageProfile-AchievementRow-Pill text-p-3"><%= t("achievement_categories.#{g[:category]}", default: g[:category].to_s.titleize) %></span>
                      </div>
                      <div class="text-p-3"><%= g[:tier].description %></div>
                      <% if g[:tiers_total] > 1 %>
                        <div class="text-p-3 PageProfile-AchievementRow-Tier">
                          <%= t('pages.profile.achievements.tier', current: g[:tiers_completed] + (g[:all_completed] ? 0 : 1), total: g[:tiers_total]) %>
                        </div>
                      <% end %>
                    </div>
                    <% unless g[:all_completed] %>
                      <div class="PageProfile-AchievementRow-Progress text-p-3">
                        <%= g[:progress] %> / <%= g[:target] %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-p-3"><%= t('pages.profile.empty.achievements') %></p>
            <% end %>

          <% when 'titles' %>
            <% if @available_titles.present? %>
              <p class="text-p-3"><%= t('pages.profile.titles.section_hint') %></p>
              <div class="PageProfile-Titles-Grid">
                <% @available_titles.each do |title| %>
                  <% is_current = @user.current_title_id == title.id %>
                  <%= form_with url: select_title_path, method: :patch, local: true, class: 'PageProfile-TitleForm' do %>
                    <%= hidden_field_tag :title_id, title.id %>
                    <button type="submit"
                            class="PageProfile-TitleCard <%= 'PageProfile-TitleCard--Current' if is_current %>"
                            <%= 'disabled' if is_current %>>
                      <span class="PageProfile-TitleCard-Name text-p-2"><%= title.name %></span>
                      <% if title.description.present? %>
                        <span class="PageProfile-TitleCard-Desc text-p-3"><%= title.description %></span>
                      <% end %>
                      <% if is_current %>
                        <span class="PageProfile-TitleCard-Badge text-p-3"><%= t('pages.profile.titles.selected') %></span>
                      <% end %>
                    </button>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <p class="text-p-3"><%= t('pages.profile.titles.no_titles') %></p>
            <% end %>

          <% when 'rewards' %>
            <%# Все возможные награды: открытые показываются как есть, закрытые с пометкой "закрыто" + текст ачивки %>
            <% completed_ach_ids = @completed_achievements.map(&:achievement_id).to_set %>
            <% title_achs = Achievement.where.not(title_id: nil).includes(:title).order(:progress_target) %>
            <% theme_achs = Achievement.where.not(reward_theme: nil).order(:progress_target) %>
            <% badge_achs = Achievement.where.not(reward_badge_label: nil).order(:progress_target) %>

            <% if title_achs.any? %>
              <div class="PageProfile-RewardSection">
                <h4 class="text-p-3 PageProfile-RewardSection-Title"><%= t('pages.profile.rewards.titles_heading') %></h4>
                <div class="PageProfile-RewardList">
                  <% title_achs.each do |a| %>
                    <% earned = completed_ach_ids.include?(a.id) %>
                    <div class="PageProfile-RewardRow <%= 'PageProfile-RewardRow--Locked' unless earned %>">
                      <div class="PageProfile-RewardRow-Title text-p-2"><%= a.title.name %></div>
                      <div class="PageProfile-RewardRow-From text-p-3">
                        <%= t('pages.profile.rewards.from', name: a.name) %><% unless earned %> · <%= t('pages.profile.rewards.locked', default: 'закрыто') %><% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>

            <% if theme_achs.any? %>
              <div class="PageProfile-RewardSection">
                <h4 class="text-p-3 PageProfile-RewardSection-Title"><%= t('pages.profile.rewards.themes_heading') %></h4>
                <div class="PageProfile-RewardThemes">
                  <% theme_achs.each do |a|
                       t_key   = a.reward_theme
                       earned  = completed_ach_ids.include?(a.id) %>
                    <div class="PageProfile-RewardTheme <%= 'PageProfile-RewardTheme--Locked' unless earned %>" title="<%= a.name %>">
                      <div class="O_ThemePickerModal-Card-Preview PageProfile-RewardTheme-Preview" data-theme="<%= t_key %>">
                        <span class="O_ThemePickerModal-Card-Bar"></span>
                        <span class="O_ThemePickerModal-Card-Surface"></span>
                        <span class="O_ThemePickerModal-Card-Line O_ThemePickerModal-Card-Line--1"></span>
                        <span class="O_ThemePickerModal-Card-Line O_ThemePickerModal-Card-Line--2"></span>
                        <span class="O_ThemePickerModal-Card-Line O_ThemePickerModal-Card-Line--3"></span>
                        <span class="O_ThemePickerModal-Card-Accent"></span>
                      </div>
                      <span class="PageProfile-RewardTheme-Name text-p-3"><%= t("pages.profile_config.preferences.theme_options.#{t_key}", default: t_key.titleize) %></span>
                      <span class="PageProfile-RewardTheme-From text-p-3"><%= a.name %><% unless earned %> · <%= t('pages.profile.rewards.locked', default: 'закрыто') %><% end %></span>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>

            <% if badge_achs.any? %>
              <div class="PageProfile-RewardSection">
                <h4 class="text-p-3 PageProfile-RewardSection-Title"><%= t('pages.profile.rewards.badges_heading') %></h4>
                <div class="PageProfile-RewardBadges">
                  <% badge_achs.each do |a|
                       earned = completed_ach_ids.include?(a.id) %>
                    <div class="PageProfile-RewardBadge <%= 'PageProfile-RewardBadge--Locked' unless earned %>" title="<%= a.name %>">
                      <span class="PageProfile-RewardBadge-Label text-p-3"><%= a.reward_badge_label %></span>
                      <span class="PageProfile-RewardBadge-From text-p-3"><%= a.name %><% unless earned %> · <%= t('pages.profile.rewards.locked', default: 'закрыто') %><% end %></span>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>

            <% if title_achs.empty? && theme_achs.empty? && badge_achs.empty? %>
              <p class="text-p-3"><%= t('pages.profile.empty.rewards') %></p>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="PageProfile-Col PageProfile-Col--Missions">
      <%= render 'pages/profile/missions', extra_class: 'PageProfile-Missions--Standalone' %>
    </div>

  </section>
</div>
