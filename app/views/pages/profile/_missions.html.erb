<div class="PageProfile-Card PageProfile-Missions <%= local_assigns[:extra_class] %>">
  <div class="PageProfile-Missions-Section">
    <h3 class="text-p-3 PageProfile-Card-Title"><%= t('pages.profile.missions.current') %></h3>
    <% if @current_interactive %>
      <div class="PageProfile-MissionItem PageProfile-MissionItem--Active">
        <span class="PageProfile-MissionItem-Title text-p-3"><%= @current_interactive.title %></span>
      </div>
    <% else %>
      <p class="text-p-3 PageProfile-MissionItem-Empty"><%= t('pages.profile.missions.current_empty') %></p>
    <% end %>
  </div>

  <div class="PageProfile-Missions-Section">
    <h3 class="text-p-3 PageProfile-Card-Title"><%= t('pages.profile.missions.completed') %></h3>
    <% if @completed_interactives.any? %>
      <div class="PageProfile-MissionList">
        <% @completed_interactives.each do |c| %>
          <div class="PageProfile-MissionItem PageProfile-MissionItem--Completed">
            <span class="PageProfile-MissionItem-Title text-p-3"><%= c.interactive&.title || c.interactive_key %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-p-3 PageProfile-MissionItem-Empty"><%= t('pages.profile.missions.completed_empty') %></p>
    <% end %>
  </div>
</div>
