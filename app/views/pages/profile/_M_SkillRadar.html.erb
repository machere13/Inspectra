<%
  rows        = Array(local_assigns[:rows] || [])
  size        = 500
  vb_pad_x    = 36
  vb_crop_y   = 0
  vb_x        = -vb_pad_x
  vb_y        = vb_crop_y
  vb_w        = size + 2 * vb_pad_x
  vb_h        = size - 2 * vb_crop_y
  cx          = size / 2.0
  cy          = size / 2.0
  radius      = (size / 2.0) - 80
  axes_count  = rows.length
  rings       = 7
  label_ratio = 1.20

  axis_point = ->(i, ratio) {
    angle = (-Math::PI / 2.0) + (i * 2.0 * Math::PI / axes_count.to_f)
    [cx + radius * ratio * Math.cos(angle), cy + radius * ratio * Math.sin(angle)]
  }

  ring_polys = (1..rings).map do |r|
    ratio = r / rings.to_f
    (0...axes_count).map { |i| axis_point.call(i, ratio).map { |v| v.round(2) }.join(',') }.join(' ')
  end
  inner_rings = ring_polys[0..-2]
  outer_ring  = ring_polys.last

  has_data = rows.any? { |r| r[:percent].to_i > 0 }
  data_pts_arr = rows.each_with_index.map do |row, i|
    pct = [[row[:percent].to_i, 0].max, 100].min
    axis_point.call(i, pct / 100.0)
  end
  data_pts = data_pts_arr.map { |x, y| "#{x.round(2)},#{y.round(2)}" }.join(' ')

  vertex_ticks = (0...axes_count).map do |i|
    p_in  = axis_point.call(i, 1.0)
    p_out = axis_point.call(i, 1.06)
    [p_in[0].round(2), p_in[1].round(2), p_out[0].round(2), p_out[1].round(2)]
  end

  label_positions = rows.each_with_index.map do |row, i|
    x, y = axis_point.call(i, label_ratio)
    anchor = if x.round == cx.round then 'middle'
             elsif x < cx then 'end'
             else 'start'
             end
    y -= 24 if i == 0
    { x: x.round(2), y: y.round(2), text: row[:label].to_s.upcase, anchor: anchor, percent: row[:percent].to_i }
  end

  cross_r = radius * 0.55
  diag1 = [cx - cross_r * Math.cos(Math::PI / 4), cy - cross_r * Math.sin(Math::PI / 4),
           cx + cross_r * Math.cos(Math::PI / 4), cy + cross_r * Math.sin(Math::PI / 4)]
  diag2 = [cx - cross_r * Math.cos(Math::PI / 4), cy + cross_r * Math.sin(Math::PI / 4),
           cx + cross_r * Math.cos(Math::PI / 4), cy - cross_r * Math.sin(Math::PI / 4)]
%>

<div class="M_SkillRadar">
  <svg viewBox="<%= vb_x %> <%= vb_y %> <%= vb_w %> <%= vb_h %>" class="M_SkillRadar-Svg" aria-hidden="true">
    <defs>
      <pattern id="M_SkillRadar-BgDots" x="0" y="0" width="11" height="11" patternUnits="userSpaceOnUse">
        <circle cx="1" cy="1" r="0.55" class="M_SkillRadar-BgDot"/>
      </pattern>
      <filter id="M_SkillRadar-Glow" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="2.4" result="blur"/>
        <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
    </defs>

    <rect x="<%= vb_x %>" y="<%= vb_y %>" width="<%= vb_w %>" height="<%= vb_h %>" fill="url(#M_SkillRadar-BgDots)"/>

    <% inner_rings.each do |poly| %>
      <polygon points="<%= poly %>" class="M_SkillRadar-Ring"/>
    <% end %>
    <polygon points="<%= outer_ring %>" class="M_SkillRadar-Ring M_SkillRadar-Ring--Outer"/>

    <% axes_count.times do |i| %>
      <% x2, y2 = axis_point.call(i, 1).map { |v| v.round(2) } %>
      <line x1="<%= cx %>" y1="<%= cy %>" x2="<%= x2 %>" y2="<%= y2 %>" class="M_SkillRadar-Axis"/>
    <% end %>

    <line x1="<%= diag1[0].round(2) %>" y1="<%= diag1[1].round(2) %>" x2="<%= diag1[2].round(2) %>" y2="<%= diag1[3].round(2) %>" class="M_SkillRadar-InnerCross"/>
    <line x1="<%= diag2[0].round(2) %>" y1="<%= diag2[1].round(2) %>" x2="<%= diag2[2].round(2) %>" y2="<%= diag2[3].round(2) %>" class="M_SkillRadar-InnerCross"/>

    <% if has_data %>
      <polygon points="<%= data_pts %>" class="M_SkillRadar-Data" filter="url(#M_SkillRadar-Glow)"/>
      <% data_pts_arr.each do |x, y| %>
        <circle cx="<%= x.round(2) %>" cy="<%= y.round(2) %>" r="4" class="M_SkillRadar-Dot" filter="url(#M_SkillRadar-Glow)"/>
      <% end %>
    <% end %>

    <% vertex_ticks.each do |x1, y1, x2, y2| %>
      <line x1="<%= x1 %>" y1="<%= y1 %>" x2="<%= x2 %>" y2="<%= y2 %>" class="M_SkillRadar-VertexTick"/>
    <% end %>

    <circle cx="<%= cx %>" cy="<%= cy %>" r="1.5" class="M_SkillRadar-Center"/>

    <% label_positions.each do |pos| %>
      <text x="<%= pos[:x] %>" y="<%= pos[:y] %>" class="M_SkillRadar-Label" text-anchor="<%= pos[:anchor] %>">
        <%= pos[:text] %>
      </text>
      <text x="<%= pos[:x] %>" y="<%= pos[:y] + 24 %>" class="M_SkillRadar-LabelPercent" text-anchor="<%= pos[:anchor] %>">
        <%= pos[:percent] %>%
      </text>
    <% end %>
  </svg>
</div>
