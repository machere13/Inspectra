<% if local_assigns[:admin_navigation] %>
  <%
    is_admin_week_page = request.path.match?(%r{^/admin/weeks/}) && !@week.nil? && @week.persisted?
    admin_navigation_items = [
      { text: 'ПАНЕЛЬ', href: admin_dashboard_path, hotkey: 'П' },
      { text: 'ЮЗЕРЫ', href: admin_users_path, hotkey: 'Ю' },
      { text: 'НЕДЕЛИ', href: admin_weeks_path, hotkey: 'Н' },
      { text: 'ОТЧЁТЫ', href: admin_error_reports_path, hotkey: 'О' },
      { text: 'МЕДИА', href: admin_media_subscriptions_path, hotkey: 'М' }
    ]
    week_navigation_items = nil
    if is_admin_week_page
      week_navigation_items = [
        { text: 'СТАТЬИ', href: admin_week_articles_path(@week), hotkey: 'С' },
        { text: 'КОНТЕНТ', href: admin_week_content_items_path(@week), hotkey: 'К' }
      ]
    end
  %>
  <div class="W_NavigationContent">
    <%= render 'shared/wrappers/W_NavigationItems', index: 0, items: admin_navigation_items %>
    <% if week_navigation_items %>
      <%= render 'shared/wrappers/W_NavigationItems', index: 1, items: week_navigation_items %>
    <% end %>
  </div>
<% else %>
  <% is_home = request.path == '/' || request.path == '/pages/home' %>
  <% is_week_page = request.path.include?('/weeks/') %>
  <% is_article_page = request.path.include?('/articles/') %>
  <% is_inspectra_page = request.path == '/inspectra' || request.path == inspectra_path %>
  <% is_profile_page = request.path == '/profile' || request.path.start_with?('/profile/') %>
  <%
    article_count = is_week_page && defined?(@week) ? @week.articles.count : 0
    filter_items = is_week_page && defined?(@content_counts) ? [
      { label: "Статьи (#{article_count})", value: 'article', checked: false },
      { label: "Картинки (#{@content_counts['image'] || 0})", value: 'image', checked: false },
      { label: "GIF (#{@content_counts['gif'] || 0})", value: 'gif', checked: false },
      { label: "Видео (#{@content_counts['video'] || 0})", value: 'video', checked: false },
      { label: "Аудио (#{@content_counts['audio'] || 0})", value: 'audio', checked: false },
      { label: "Ссылки (#{@content_counts['link'] || 0})", value: 'link', checked: false }
    ] : []
    navigation_items = [
      { text: 'ГЛАВНАЯ', href: root_path, hotkey: 'Г' },
      { text: 'ИНСПЕКТРА', href: inspectra_path, hotkey: 'И' }
    ]
    if defined?(current_user) && current_user&.email_verified?
      navigation_items << { text: 'ПРОФИЛЬ', href: profile_path, hotkey: 'П' }
    else
      navigation_items << { text: 'ВХОД', href: auth_path, hotkey: 'В' }
    end
  %>

  <div class="W_NavigationContent">
    <%= render 'shared/wrappers/W_NavigationItems', index: 0, items: navigation_items %>

    <% if is_week_page %>
      <%= render 'shared/wrappers/W_NavigationItems', index: 1, items: filter_items, radio: true %>
    <% elsif is_inspectra_page %>
      <%= render 'shared/wrappers/W_NavigationItems', index: 1, items: [
        { text: 'ГЛАВНОЕ', href: '#main' },
        { text: 'О НАС', href: '#about' },
        { text: 'ТВОЯ РОЛЬ', href: '#your_role' },
        { text: 'КАК', href: '#how' },
        { text: 'ГОТОВ', href: '#ready' },
      ] %>
    <% elsif is_profile_page %>
      <%= render 'shared/wrappers/W_NavigationItems', index: 1, items: [
        { text: 'ОБЗОР', href: profile_path, hotkey: 'О' },
        { text: 'НАСТРОЙКИ', href: profile_config_path, hotkey: 'Н' }
      ] %>
    <% elsif !is_article_page && !@error_page %>
      <%= render 'shared/wrappers/W_NavigationItems', index: 1, items: [
        { text: 'БЛОКИ', href: '#blocks' }
      ], style: is_home ? 'visibility: hidden; opacity: 0; height: 0;' : '' %>
    <% elsif @error_page %>
      <%= render 'shared/wrappers/W_NavigationItems', index: 1, items: [], style: 'visibility: hidden; pointer-events: none; overflow: hidden;', aria_hidden: true %>
    <% end %>
  </div>
<% end %>
