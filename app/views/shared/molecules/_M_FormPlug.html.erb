<%= form_with url: inspectra_subscribe_path, method: :post, local: true, class: 'M_FormPlug', id: 'formPlug' do %>
  <%= render 'shared/atoms/A_Input',
    name: 'email',
    type: 'email',
    value: @media_subscription&.email,
    placeholder: 'E-mail',
    required: true,
    autocomplete: 'email',
    autocapitalize: 'none',
    spellcheck: false %>
  <%= render 'shared/atoms/A_Button', text: 'ПОДПИСАТЬСЯ', type: 'submit' %>
<% end %>