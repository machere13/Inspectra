<%
  session = @session_token || @session&.attempts_record&.session_token
  expected = interactive.issue_token_for(current_user, variant: variant)
%>
<div class="PageInteractive-Scene">
  <p class="text-p-2">Внизу iframe c устаревшей страницей. Открой его — внутри есть кодовое слово.</p>
  <iframe src="<%= legacy_iframe_path(variant&.seed, session: session) %>"
          class="PageInteractive-Iframe"
          referrerpolicy="no-referrer"
          title="legacy"></iframe>
  <p class="text-p-3">Подсказка: кодовое слово — внутри тега <code>.secret</code>.</p>

  <% if variant&.hint.present? %>
    <details class="PageInteractive-Hint"><summary class="text-p-3">Подсказка</summary><p class="text-p-3"><%= variant.hint %></p></details>
  <% end %>
  <% if Rails.env.development? && variant %><p class="text-p-3">Dev-ответ: <code><%= expected %></code></p><% end %>
</div>
