<%
  initial_code = variant&.payload&.dig('broken_code') || ''
  expected_output = variant&.payload&.dig('expected_output').to_s
  required_patterns = Array(variant&.payload&.dig('required_patterns'))
  success_token = interactive.randomizable? ? interactive.issue_token_for(current_user, variant: variant) : variant&.expected_answer
%>
<div class="PageInteractive-Scene PageInteractive-Sandbox"
     data-interactive-sandbox
     data-expected-output="<%= expected_output %>"
     data-success-token="<%= success_token %>"
     data-required-patterns="<%= required_patterns.join('|') %>"
     data-target-input='input[name="answer"]'>
  <p class="text-p-2">
    Дан сломанный код. Исправь его в редакторе и нажми «Запустить».
    Цель — получить в выводе: <code><%= expected_output %></code>.
  </p>

  <% if variant&.payload&.dig('bugs') %>
    <p class="text-p-3">Известных багов в коде:</p>
    <ul class="text-p-3 <%= 'PageInteractive-WarriorBugs' if current_user&.game_role_warrior? %>">
      <% Array(variant.payload['bugs']).each do |bug| %>
        <li><%= bug %></li>
      <% end %>
    </ul>
    <% if current_user&.game_role_warrior? %>
      <p class="text-p-3 PageInteractive-RolePerk"><strong>Перк Воина:</strong> список багов подсвечен. Плюс одна дополнительная попытка.</p>
    <% end %>
  <% end %>

  <% if required_patterns.any? %>
    <p class="text-p-3">
      Код должен содержать: <%= required_patterns.map { |p| "<code>#{ERB::Util.h(p)}</code>" }.join(', ').html_safe %>.
      Простой <code>console.log("ответ")</code> не сработает — нужен реальный фикс логики.
    </p>
  <% end %>

  <% if local_assigns[:max_attempts] %>
    <p class="text-p-3 PageInteractive-AttemptsBadge">
      ⚠ Максимум попыток: <%= local_assigns[:max_attempts] %>.
      <% if local_assigns[:attempts_left] %>
        Осталось: <strong><%= local_assigns[:attempts_left] %></strong>.
      <% end %>
      После исчерпания интерактив блокируется на 1 час.
    </p>
  <% end %>

  <label class="text-p-3" for="sandbox-code">Код (можно править):</label>
  <textarea class="PageInteractive-Sandbox-Editor text-code"
            id="sandbox-code"
            data-sandbox-editor
            spellcheck="false"
            rows="10"><%= initial_code %></textarea>

  <div class="PageInteractive-Sandbox-Controls">
    <button type="button" class="A_Button" data-sandbox-run>
      <span class="A_Button-Content text-button">Запустить</span>
    </button>
    <button type="button" class="A_Button" data-sandbox-reset>
      <span class="A_Button-Content text-button">Сбросить</span>
    </button>
  </div>

  <div class="PageInteractive-Sandbox-Output">
    <p class="text-p-3">Вывод:</p>
    <pre class="PageInteractive-Code text-code" data-sandbox-output>—</pre>
    <p class="text-p-3" data-sandbox-status>Жду запуска…</p>
  </div>

  <% if variant&.payload&.dig('fix_hint') %>
    <p class="text-p-3"><em>Намёк на фикс:</em> <%= variant.payload['fix_hint'] %></p>
  <% end %>
  <% if variant&.hint.present? %>
    <details class="PageInteractive-Hint"><summary class="text-p-3">Подсказка</summary><p class="text-p-3"><%= variant.hint %></p></details>
  <% end %>
</div>
