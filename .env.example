# Скопируй этот файл в .env и заполни локальные значения.
# .env игнорируется git'ом (см. .gitignore).

# --- PostgreSQL ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=
DATABASE_NAME_DEVELOPMENT=project3_1_development
DATABASE_NAME_TEST=project3_1_test

# ALLOWED_CORS_ORIGINS=https://example.com,https://staging.example.com

# --- JWT ---
# JWT_ISSUER=inspectra
# JWT_AUDIENCE=inspectra-api
# JWT_TOKEN_TTL_HOURS=168

# --- Auth ---
# VERIFICATION_CODE_TTL_MINUTES=15
# RESET_PASSWORD_TOKEN_TTL_MINUTES=30
# RESEND_CODE_COOLDOWN_SECONDS=60
# PASSWORD_MIN_LENGTH=8
# PASSWORD_MAX_LENGTH=64

# --- Email (SMTP) ---
# DEFAULT_EMAIL_USERNAME=
# DEFAULT_EMAIL_PASSWORD=
# SMTP_PORT=587

# --- Platform lifetime ---
# Используются достижениями "Вместе от начала до конца" и "Последний свидетель".
# Если не задать — соответствующие достижения не сработают.
# PLATFORM_START_DATE=2026-01-01
# PLATFORM_END_DATE=2026-12-31

# --- App ---
# SEED=mock        # real | mock | all
# MAILER_HOST=localhost
# RAILS_LOG_LEVEL=info
